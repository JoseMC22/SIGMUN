# Variables de Entorno de EJEMPLO - Backend SIGMUN
# Copia este archivo como .env y completa los valores reales
# NUNCA subas el archivo .env real al repositorio

# ─── Servidor ─────────────────────────────────────────────
PORT=3001

# ─── Base de Datos SQL Server ─────────────────────────────
DB_USER=
DB_PASSWORD=
DB_SERVER=
DB_DATABASE=
DB_PORT=1433
DB_ENCRYPT=false

DATABASE_URL="sqlserver://${DB_SERVER}:${DB_PORT};database=${DB_DATABASE};user=${DB_USER};password=${DB_PASSWORD};encrypt=${DB_ENCRYPT}"

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=CAMBIA_ESTE_VALOR_POR_UNA_FRASE_SECRETA_LARGA
JWT_EXPIRES_IN=8h

# ─── Frontend / Dev ---------------------------------------------------------
# URL de la aplicación frontend usada para CORS en backend
FRONTEND_URL=http://localhost:3000

# Origen permitido para HMR/dev en la LAN (ajusta a tu IP si accedes desde otra máquina)
DEV_ALLOWED_ORIGIN=http://192.168.3.244:3000
DEV_ALLOWED_ORIGIN_HOST=192.168.3.244

# Entorno de ejecución (development|production)
NODE_ENV=development
